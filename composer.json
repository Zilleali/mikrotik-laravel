{
    "name": "zilleali/mikrotik-laravel",
    "description": "MikroTik RouterOS API for Laravel — PPPoE, Hotspot, Queues & Monitoring",
    "keywords": [
        "mikrotik",
        "routeros",
        "laravel",
        "isp",
        "pppoe",
        "hotspot",
        "networking"
    ],
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Zill E Ali",
            "email": "zilleali1245@gmail.com",
            "homepage": "https://zilleali.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0"
    },
    "require-dev": {
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0",
        "orchestra/testbench": "^9.0|^10.0",
        "friendsofphp/php-cs-fixer": "^3.0"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "autoload": {
        "psr-4": {
            "ZillEAli\\MikrotikLaravel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "ZillEAli\\MikrotikLaravel\\MikrotikServiceProvider"
            ],
            "aliases": {
                "MikroTik": "ZillEAli\\MikrotikLaravel\\Facades\\MikroTik"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}